# Copy to .dev.vars (gitignored) for local wrangler dev
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
JWT_SECRET=replace-with-long-random-string-at-least-32-chars
# Use WECHAT_APPID=dev for local mock openid (code accepted as-is / dev:xxx)
WECHAT_APPID=dev
WECHAT_SECRET=dev_secret
ADMIN_USERNAME=admin
# Plaintext admin password from env (platform secret type is a deploy concern)
ADMIN_PASSWORD=replace-with-admin-password
